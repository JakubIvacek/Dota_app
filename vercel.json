{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/valve/:path*", "destination": "https://www.dota2.com/:path*" },
    { "source": "/steamnews/:path*", "destination": "https://api.steampowered.com/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
